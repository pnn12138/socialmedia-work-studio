# ==========================================
# 绘图技能 API Keys 配置
# ==========================================
# 请将此文件保存在项目根目录：.env
# 不要将包含真实 API Key 的 .env 文件提交到 Git
# ==========================================

# ------------------------------------------
# 图片库 API（免费）
# ------------------------------------------

# Pexels API - 免费高质量图片
# 获取地址：https://www.pexels.com/api/
PEXELS_API_KEY=

# Unsplash API - 免费摄影师社区图片
# 获取地址：https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Pixabay API - 免费多类型图片
# 获取地址：https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ------------------------------------------
# AI 图像生成 API（付费）
# ------------------------------------------

# OpenAI API - DALL-E 3 图像生成
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Replicate API - Stable Diffusion 等开源模型
# 获取地址：https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ------------------------------------------
# 图像编辑 API
# ------------------------------------------

# ClipDrop API - 去背、放大、重打光等
# 获取地址：https://clipdrop.co/apis
CLIPDROP_API_KEY=

# Remove.bg API - 专注去背景
# 获取地址：https://www.remove.bg/api
REMOVE_BG_API_KEY=
